<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} | Imran Jabrayilov" : "Imran Jabrayilov — Software Engineer")</title>
    <meta name="description" content="Portfolio of Imran Jabrayilov — Software Engineer specialising in .NET, Go, and cloud-native infrastructure."/>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>

    <!-- Theme -->
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true"/>

    @await RenderSectionAsync("Head", required: false)
</head>
<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-bracket">&lt;</span>IJ<span class="brand-bracket">/&gt;</span>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarContent" aria-controls="navbarContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <i class="fas fa-bars"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkExperience" ? "active" : "")"
                       asp-controller="WorkExperience" asp-action="Index">Experience</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Skills" ? "active" : "")"
                       asp-controller="Skills" asp-action="Index">Skills</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")"
                       asp-controller="Projects" asp-action="Index">Projects</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Education" ? "active" : "")"
                       asp-controller="Education" asp-action="Index">Education</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main>
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="container">
        <div class="footer-inner">
            <a class="footer-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-bracket">&lt;</span>IJ<span class="brand-bracket">/&gt;</span>
            </a>
            <span class="footer-copy">&copy; @DateTime.UtcNow.Year Imran Jabrayilov</span>
            <div class="footer-links">
                <a href="https://github.com/imran-jabrayil" target="_blank" rel="noopener" aria-label="GitHub">
                    <i class="fab fa-github"></i>
                </a>
                <a href="https://www.linkedin.com/in/imran-jabrayilov/" target="_blank" rel="noopener" aria-label="LinkedIn">
                    <i class="fab fa-linkedin-in"></i>
                </a>
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/portfolio.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
