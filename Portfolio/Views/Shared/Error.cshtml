@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="section" style="padding-top: 7rem; text-align: center;">
    <div class="container">
        <p class="section-tag">oops</p>
        <h1 class="hero-name" style="font-size: 6rem; background: linear-gradient(135deg, #ff4d4f, #ff7875); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">500</h1>
        <h2 class="section-title mt-2">Something went wrong</h2>
        <p style="color: var(--text-secondary); margin-top: 1rem;">An unexpected error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p style="margin-top: 1rem;">
                <span style="color: var(--text-muted); font-size: 0.85rem;">Request ID: </span>
                <code style="font-family: var(--font-mono); color: var(--accent); font-size: 0.8rem;">@Model.RequestId</code>
            </p>
        }

        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-glow">
                <i class="fas fa-home me-2"></i>Back to Home
            </a>
        </div>
    </div>
</div>
