@model List<Portfolio.Models.WorkExperienceTimelineBlock>

@{
    ViewData["Title"] = "Experience";
}

<div class="section page-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">experience</span>
            <h2 class="section-title">Work History</h2>
            <p class="section-subtitle">My professional journey — ordered from most recent.</p>
        </div>

        @if (Model.Any())
        {
            <div class="full-timeline">
                @foreach (var block in Model)
                {
                    <div class="ft-block">
                        <div class="ft-company-header">
                            <div class="ft-dot"></div>
                            <h3 class="ft-company-name">
                                @if (!string.IsNullOrEmpty(block.CompanyUrl))
                                {
                                    <a href="@block.CompanyUrl" target="_blank" rel="noopener">
                                        @block.Company <i class="fas fa-external-link-alt fa-xs opacity-50 ms-1"></i>
                                    </a>
                                }
                                else
                                {
                                    @block.Company
                                }
                            </h3>
                        </div>

                        <div class="ft-roles">
                            @foreach (var exp in block.WorkExperienceList)
                            {
                                <div class="ft-role-card">
                                    <div class="ft-role-top">
                                        <span class="ft-position">@exp.Position</span>
                                        <span class="ft-badge">
                                            @exp.StartDate.ToString("MMM yyyy") &mdash;
                                            @(exp.TerminationDate?.ToString("MMM yyyy") ?? "Present")
                                        </span>
                                    </div>
                                    <div class="ft-location">
                                        <i class="fas fa-map-marker-alt fa-xs me-1"></i>
                                        @exp.City, @exp.Country
                                    </div>
                                    @if (exp.Description?.Count > 0)
                                    {
                                        <ul class="ft-bullets">
                                            @foreach (var bullet in exp.Description)
                                            {
                                                <li>@bullet</li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-glow">
                    <i class="fas fa-arrow-left me-2"></i>Back to Portfolio
                </a>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-briefcase fa-3x mb-3 opacity-25"></i>
                <p>No work experience records yet.</p>
            </div>
        }
    </div>
</div>
